# AegisGraph Sentinel 2.0 - Environment Variables Configuration
# Copy this file to .env and update values for your environment

# ============================================================================
# Environment Configuration
# ============================================================================

# Application environment (development, staging, production)
AEGIS_ENVIRONMENT=development

# Debug mode (true/false)
DEBUG=false

# ============================================================================
# API Configuration
# ============================================================================

# API host address
API_HOST=0.0.0.0

# API port number (1-65535)
API_PORT=8000

# Enable auto-reload on code changes (development only)
API_RELOAD=true

# API logging level (debug, info, warning, error, critical)
API_LOG_LEVEL=info

# External API URL (required for production)
API_URL=http://localhost:8000

# ============================================================================
# CORS Configuration
# ============================================================================

# Comma-separated list of allowed CORS origins
# Examples: http://localhost:3000,https://app.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8501,http://127.0.0.1:8501

# ============================================================================
# Rate Limiting
# ============================================================================

# Rate limit configuration (format: requests/time_unit)
# Examples: 100/minute, 1000/hour, 10000/day
RATE_LIMIT=100/minute

# Maximum batch processing size
MAX_BATCH_SIZE=100

# ============================================================================
# Data and Models
# ============================================================================

# Path to knowledge graph file
GRAPH_PATH=data/synthetic/graph.graphml

# Expected SHA256 hash of graph file (optional, for validation)
AEGIS_GRAPH_SHA256=

# Model paths and configuration
MODEL_PATH=models/htgnn_best.pt

# Computation device (cpu, cuda, mps)
DEVICE=cpu

# ============================================================================
# Risk Scoring Thresholds
# ============================================================================

# Risk threshold for "ALLOW" decision (0.0-1.0)
RISK_THRESHOLD_ALLOW=0.50

# Risk threshold for "REVIEW" decision (0.0-1.0)
RISK_THRESHOLD_REVIEW=0.70

# Risk threshold for "BLOCK" decision (0.0-1.0)
RISK_THRESHOLD_BLOCK=0.90

# ============================================================================
# Component Weights
# ============================================================================

# Graph component weight (0.0-1.0)
COMPONENT_WEIGHT_GRAPH=0.50

# Velocity component weight (0.0-1.0)
COMPONENT_WEIGHT_VELOCITY=0.20

# Behavior component weight (0.0-1.0)
COMPONENT_WEIGHT_BEHAVIOR=0.20

# Entropy component weight (0.0-1.0)
COMPONENT_WEIGHT_ENTROPY=0.10

# ============================================================================
# Lateral Movement Detection
# ============================================================================

# Standard deviation multiplier for lateral movement detection
LATERAL_MOVEMENT_STD_MULTIPLIER=2.0

# Threshold multiplier for lateral movement
LATERAL_MOVEMENT_THRESHOLD_MULTIPLIER=3.0

# Risk increment for lateral movement
LATERAL_MOVEMENT_RISK_INCREMENT=0.25

# History size for lateral movement analysis
LATERAL_MOVEMENT_HISTORY_SIZE=10

# ============================================================================
# Honeypot/Escrow Configuration
# ============================================================================

# Honeypot escrow timeout in seconds
HONEYPOT_ESCROW_SECONDS=900

# Honeypot activation threshold (0.0-1.0)
HONEYPOT_ACTIVATION_THRESHOLD=0.90

# Honeypot critical indicator threshold (0.0-1.0)
HONEYPOT_CRITICAL_INDICATOR_THRESHOLD=0.80

# ============================================================================
# Voice Stress Analysis
# ============================================================================

# Voice stress threshold
VOICE_STRESS_THRESHOLD=30.0

# Voice coercion threshold
VOICE_COERCION_THRESHOLD=75.0

# ============================================================================
# Predictive Mule Identification
# ============================================================================

# Predictive mule risk threshold
PREDICTIVE_MULE_RISK_THRESHOLD=75.0

# ============================================================================
# Observability and Logging
# ============================================================================

# Application logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log format (json or text)
LOG_FORMAT=json

# Log output directory
LOG_OUTPUT_DIR=logs

# ============================================================================
# Monitoring and Metrics
# ============================================================================

# Prometheus metrics port
PROMETHEUS_PORT=9090

# ============================================================================
# Configuration File Paths
# ============================================================================

# Path to runtime configuration YAML
AEGIS_CONFIG_PATH=config/config.yaml

# Path to risk thresholds YAML
AEGIS_THRESHOLDS_PATH=config/thresholds.yaml

# ============================================================================
# External Services
# ============================================================================

# Redis connection URL (optional)
# Format: redis://[user]:[password]@[host]:[port]/[db]
REDIS_URL=

# ============================================================================
# Authentication
# ============================================================================

# API key hashes (comma-separated list of SHA-256 hashes)
# Generate hash: echo -n "your_api_key" | sha256sum
# AEGIS_API_KEY_HASHES=abc123def456,ghi789jkl012

# GPU Configuration (if using CUDA)
CUDA_VISIBLE_DEVICES=0

# Neo4j Database Credentials
# Use encrypted schemes (neo4j+ssc:// or neo4j+s://) for production
AEGIS_NEO4J_URI=neo4j+ssc://localhost:7687
AEGIS_NEO4J_USER=neo4j
AEGIS_NEO4J_PASSWORD=your_secure_password
# Set to false to allow unencrypted connections (not recommended for production)
AEGIS_NEO4J_REQUIRE_ENCRYPTION=true
